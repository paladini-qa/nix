# ==========================================
# FINANCAS INTELIGENTES - Variaveis de Ambiente
# ==========================================
# Copie este arquivo para .env e preencha os valores

# ------------------------------------------
# PLUGGY
# ------------------------------------------
PLUGGY_CLIENT_ID=xxx
PLUGGY_CLIENT_SECRET=xxx

# ------------------------------------------
# SUPABASE (Obrigatorio)
# ------------------------------------------
# Acesse: https://supabase.com/dashboard/project/[seu-projeto]/settings/api
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_ANON_KEY=sua_anon_key_aqui

# ------------------------------------------
# GOOGLE GEMINI AI (Opcional - para insights)
# ------------------------------------------
# Acesse: https://aistudio.google.com/apikey
GEMINI_API_KEY=sua_api_key_do_gemini_aqui

# ------------------------------------------
# GOOGLE CUSTOM SEARCH (Opcional - para buscar logos dos métodos de pagamento)
# ------------------------------------------
# Acesse: https://developers.google.com/custom-search/v1/overview
# Crie um Programmable Search Engine em: https://programmablesearchengine.google.com
# e habilite "Pesquisa de Imagens" nas configurações do mecanismo.
# ⚠️  ATENÇÃO: variáveis VITE_* são embutidas no bundle JS público.
# Antes de fazer deploy em origem pública, restrinja a chave por HTTP referrer
# em https://console.cloud.google.com/apis/credentials para evitar exaustão de quota.
VITE_GOOGLE_CSE_API_KEY=sua_api_key_do_google_aqui
VITE_GOOGLE_CSE_CX=seu_cx_do_mecanismo_aqui

# ------------------------------------------
# Error reporting (Opcional)
# ------------------------------------------
# Se definido, ErrorBoundary envia POST JSON para esta URL em caso de crash
# VITE_ERROR_REPORT_URL=https://your-endpoint.com/client-errors
